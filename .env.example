# =============================================================================
# StayAfrica - Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your actual values
# This is the single source of truth for all environment variables
# =============================================================================

# -----------------------------------------------------------------------------
# Django Core Settings
# -----------------------------------------------------------------------------
# CRITICAL: Generate a secure key using:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-this-to-a-secure-key-in-production-use-python-command-above
DEBUG=False
ALLOWED_HOSTS=api.zimlegend.online,zimlegend.online,localhost,127.0.0.1

# -----------------------------------------------------------------------------
# Database Configuration (PostgreSQL + PostGIS)
# -----------------------------------------------------------------------------
# CRITICAL: These credentials MUST be consistent across ALL services
# Generate secure password using: openssl rand -base64 32
DB_ENGINE=django.contrib.gis.db.backends.postgis
DB_NAME=stayafrica_db
DB_USER=stayafrica_user
DB_PASSWORD=CHANGE_THIS_GENERATE_SECURE_PASSWORD_32CHARS
DB_HOST=db
DB_PORT=5432

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
# CRITICAL: Set a strong Redis password in production
# Generate using: openssl rand -base64 32
# Redis password must be at least 32 characters with uppercase, lowercase, numbers, and special characters
REDIS_PASSWORD=CHANGE_THIS_GENERATE_SECURE_REDIS_PASSWORD_32CHARS
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/0

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------
# Generate using: openssl rand -base64 64
JWT_SECRET_KEY=CHANGE_THIS_GENERATE_JWT_SECRET_64CHARS
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=7
JWT_ALGORITHM=HS256

# -----------------------------------------------------------------------------
# Email Configuration
# -----------------------------------------------------------------------------
# ─── Email (SMTP) ────────────────────────────────────────────────
# Works with any external SMTP provider. Set the values for your provider:
#
# Hostinger:   EMAIL_HOST=smtp.hostinger.com   EMAIL_PORT=465  EMAIL_USE_SSL=True   EMAIL_USE_TLS=False
# Mailbaby:    EMAIL_HOST=smtp.mail.baby       EMAIL_PORT=587  EMAIL_USE_SSL=False  EMAIL_USE_TLS=True
# Gmail:       EMAIL_HOST=smtp.gmail.com       EMAIL_PORT=587  EMAIL_USE_SSL=False  EMAIL_USE_TLS=True
# AWS SES:     EMAIL_HOST=email-smtp.<region>.amazonaws.com  EMAIL_PORT=587  EMAIL_USE_TLS=True
# SendGrid:    EMAIL_HOST=smtp.sendgrid.net    EMAIL_PORT=587  EMAIL_USE_SSL=False  EMAIL_USE_TLS=True
# Mailgun:     EMAIL_HOST=smtp.mailgun.org     EMAIL_PORT=587  EMAIL_USE_SSL=False  EMAIL_USE_TLS=True
# Zoho:        EMAIL_HOST=smtp.zoho.com        EMAIL_PORT=465  EMAIL_USE_SSL=True   EMAIL_USE_TLS=False
# Brevo:       EMAIL_HOST=smtp-relay.brevo.com EMAIL_PORT=587  EMAIL_USE_SSL=False  EMAIL_USE_TLS=True
#
# NOTE: EMAIL_USE_TLS and EMAIL_USE_SSL are mutually exclusive. Never set both to True.
# Dev: set EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend to print to console.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.hostinger.com
EMAIL_PORT=465
EMAIL_USE_TLS=False
EMAIL_USE_SSL=True
EMAIL_HOST_USER=noreply@stayafrica.com
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=StayAfrica <noreply@stayafrica.com>

# -----------------------------------------------------------------------------
# Frontend Configuration
# -----------------------------------------------------------------------------
FRONTEND_URL=https://zimlegend.online
NEXT_PUBLIC_API_BASE_URL=https://api.zimlegend.online
NEXT_PUBLIC_API_VERSION=v1
NEXT_PUBLIC_APP_NAME=StayAfrica

# -----------------------------------------------------------------------------
# AWS S3 Configuration (Optional)
# -----------------------------------------------------------------------------
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
COMMISSION_RATE=0.07
SERVICE_FEE=3.00
DEFAULT_CURRENCY=USD
APP_VERSION=1.0.0

# -----------------------------------------------------------------------------
# Security Settings
# -----------------------------------------------------------------------------
CSRF_TRUSTED_ORIGINS=https://api.zimlegend.online,https://zimlegend.online

# -----------------------------------------------------------------------------
# Payment Providers (Optional)
# -----------------------------------------------------------------------------
PAYNOW_MERCHANT_ID=
PAYNOW_HASH_KEY=
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Site URL for payment gateway redirects (defaults to FRONTEND_URL if not set)
SITE_URL=

# -----------------------------------------------------------------------------
# Monitoring & Error Tracking
# -----------------------------------------------------------------------------
# REQUIRED IN PRODUCTION: Get from https://sentry.io
# Create a project and copy the DSN
SENTRY_DSN=https://YOUR_SENTRY_KEY@YOUR_SENTRY_ORG.ingest.sentry.io/YOUR_PROJECT_ID

# -----------------------------------------------------------------------------
# Erlang Messaging Service Configuration
# -----------------------------------------------------------------------------
# URL for the Erlang messaging service
# Use container name 'erlang-messaging' when running in Docker
ERLANG_MESSAGING_URL=http://erlang-messaging:8765
# Optional shared secret for secure Django-Erlang communication
ERLANG_SHARED_SECRET=

# -----------------------------------------------------------------------------
# Google Maps API (Optional)
# -----------------------------------------------------------------------------
GOOGLE_MAPS_API_KEY=

# -----------------------------------------------------------------------------
# Firebase / Push Notifications
# -----------------------------------------------------------------------------
# 1. Create a Firebase project at https://console.firebase.google.com
# 2. Download the service account JSON from Project Settings → Service accounts → Generate new private key
# 3. Save it as backend/firebase-credentials.json (gitignored — never commit!)
# 4. For web push, fill in the NEXT_PUBLIC_FIREBASE_* vars from Project Settings → General → Your apps → Web app
FIREBASE_CREDENTIALS_PATH=/app/firebase-credentials.json
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# -----------------------------------------------------------------------------
# MAPBOX Configuration (For maps)
# -----------------------------------------------------------------------------
# Get your token from https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=pk.YOUR_MAPBOX_TOKEN_HERE
